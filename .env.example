# ============================================================
# FlowBoard — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Application ---
APP_NAME="FlowBoard"
APP_ENV="development"           # development | production
DEBUG=true

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# --- Security (CRITICAL: Change in production!)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL Database ---
POSTGRES_HOST=db                # 'db' = Docker service name, 'localhost' for local
POSTGRES_PORT=5432
POSTGRES_USER=flowboard_user
POSTGRES_PASSWORD=flowboard_password
POSTGRES_DB=flowboard_db
# Assembled by the app automatically:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:port/db

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME="FlowBoard"

# --- CORS (comma-separated allowed origins)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Redis (Phase 6 — caching & pub/sub)
REDIS_HOST=redis
REDIS_PORT=6379